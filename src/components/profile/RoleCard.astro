---
import type { Role } from "@/types/iso29110";
import type { ColorTokens } from "@/constants/profile-colors";

interface Props {
  role: Role;
  tokens: ColorTokens;
}

const { role, tokens } = Astro.props;
---

<div class="bg-white border border-[#d3cec6] rounded-xl p-5">
  <div class="flex items-center gap-3 mb-3">
    <div
      class={`w-10 h-10 rounded-xl ${tokens.bg} flex items-center justify-center text-white font-bold text-sm`}
    >
      {role.abbreviation}
    </div>
    <div>
      <p class="font-medium text-[#111111] text-sm">{role.name}</p>
      <p class={`text-xs font-medium ${tokens.text}`}>{role.abbreviation}</p>
    </div>
  </div>
  <p class="text-sm text-[#626260] mb-3">{role.description}</p>
  <p class="text-sm font-medium text-[#111111] mb-2 uppercase tracking-wide">Responsabilidades</p>
  <ul class="space-y-1">
    {
      role.responsibilities.map((r) => (
        <li class="text-sm text-[#626260] flex items-start gap-1.5">
          <span class="text-[#d3cec6] mt-0.5">•</span>
          {r}
        </li>
      ))
    }
  </ul>
</div>
