---
import type { Role } from "@/types/iso29110";
import type { ColorTokens } from "@/constants/profile-colors";

interface Props {
  role: Role;
  tokens: ColorTokens;
}

const { role, tokens } = Astro.props;
---

<div class={`bg-white rounded-2xl border ${tokens.border} p-5 shadow-sm`}>
  <div class="flex items-center gap-3 mb-3">
    <div
      class={`w-10 h-10 rounded-xl ${tokens.bg} flex items-center justify-center text-white font-bold text-sm`}
    >
      {role.abbreviation}
    </div>
    <div>
      <p class="font-bold text-gray-900 text-sm">{role.name}</p>
      <p class={`text-xs font-semibold ${tokens.text}`}>{role.abbreviation}</p>
    </div>
  </div>
  <p class="text-xs text-gray-500 mb-3">{role.description}</p>
  <p class="text-xs font-bold text-gray-700 mb-2 uppercase tracking-wide">Responsabilidades</p>
  <ul class="space-y-1">
    {
      role.responsibilities.map((r) => (
        <li class="text-xs text-gray-600 flex items-start gap-1.5">
          <span class="text-gray-400 mt-0.5">•</span>
          {r}
        </li>
      ))
    }
  </ul>
</div>
