---
import "../styles/globals.css";
import Navbar from "../components/layout/Navbar.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "ISO 29110 — Guía de Perfiles para VSEs",
  description = "Guía interactiva de los perfiles ISO/IEC 29110 para Entidades Muy Pequeñas (VSEs)",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50 antialiased">
    <Navbar />
    <div class="flex-1">
      <slot />
    </div>
  </body>
</html>
