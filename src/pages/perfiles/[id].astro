---
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getDivision, getDivisionIds, getAdjacentDivisions, getDivisions } from "@/lib/divisions";
import { getProfile } from "@/lib/profiles";
import { getColorTokens } from "@/constants/profile-colors";
import ProcessSection from "../../components/process/ProcessSection";
import RoleCard from "../../components/profile/RoleCard.astro";

export function getStaticPaths() {
  return getDivisionIds().map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const division = getDivision(id!);
if (!division) return Astro.redirect("/404");

const tokens = getColorTokens(division.color);
const { prev, next } = getAdjacentDivisions(id!);
const allDivisions = getDivisions();
const currentIndex = allDivisions.findIndex((d) => d.id === id);
const profile = division.profileId ? getProfile(division.profileId) : null;

let sectionNum = 0;
function nextSection() { sectionNum++; return String(sectionNum).padStart(2, "0"); }
---

<Layout title={`Parte ${division.partNumber} — ${division.name} — ISO/IEC 29110`}>
  <main>

    <!-- Progress bar -->
    <div class="bg-[#f5f1ec] border-b border-[#ebe7e1] sticky top-14 z-40">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3 min-w-0">
          <a href="/perfiles" class="text-sm text-[#7b7b78] hover:text-[#111111] transition-colors whitespace-nowrap flex items-center gap-1.5">
            <Icon name="lucide:arrow-left" class="w-4 h-4" />
            Todos los perfiles
          </a>
          <span class="text-[#d3cec6]">|</span>
          <span class="text-sm font-medium text-[#626260] truncate">{division.name}</span>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
          <span class="text-sm text-[#7b7b78]">{currentIndex + 1} / {allDivisions.length}</span>
          <div class="w-28 h-1.5 bg-[#ebe7e1] rounded-full overflow-hidden">
            <div
              class={`h-full rounded-full ${tokens.bg}`}
              style={`width: ${((currentIndex + 1) / allDivisions.length) * 100}%`}
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Hero -->
    <div class="bg-[#f5f1ec] border-b border-[#ebe7e1]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="flex items-start gap-5">
          <div class={`w-16 h-16 rounded-2xl ${tokens.bg} flex items-center justify-center flex-shrink-0`}>
            <Icon name={`lucide:${division.icon}`} class="w-8 h-8 text-white" />
          </div>
          <div>
            <div class="flex items-center gap-2 mb-2 flex-wrap">
              <span class="text-xs font-medium text-[#626260] border border-[#d3cec6] px-3 py-1 rounded-full">
                Módulo {currentIndex + 1} de {allDivisions.length}
              </span>
              <span class="text-xs font-medium text-[#626260] border border-[#d3cec6] px-3 py-1 rounded-full">
                Parte {division.partNumber}
              </span>
              <span class="text-xs font-medium text-[#626260] border border-[#d3cec6] px-3 py-1 rounded-full">
                {division.documentType === "IS" ? "Norma Internacional" : "Informe Técnico"} · {division.year}
              </span>
            </div>
            <h1 class="text-2xl sm:text-3xl font-semibold text-[#111111] leading-snug tracking-tight">{division.name}</h1>
            <p class="text-[#7b7b78] mt-1 text-xs font-mono">
              ISO/IEC {division.documentType === "TR" ? "TR " : ""}29110-{division.partNumber}:{division.year}
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-8">

      <!-- 01 Descripción -->
      <section class="bg-white border border-[#d3cec6] rounded-xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <span class={`text-xs font-medium px-2.5 py-1 rounded-lg ${tokens.badge}`}>{nextSection()}</span>
          <h2 class="text-lg font-semibold text-[#111111]">Descripción</h2>
        </div>
        <p class="text-[#626260] leading-relaxed">{division.description}</p>
      </section>

      <!-- 02 Público Objetivo -->
      <section class="bg-white border border-[#d3cec6] rounded-xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <span class={`text-xs font-medium px-2.5 py-1 rounded-lg ${tokens.badge}`}>{nextSection()}</span>
          <h2 class="text-lg font-semibold text-[#111111]">Público Objetivo</h2>
        </div>
        <div class="flex items-start gap-3">
          <Icon name="lucide:users" class="w-6 h-6 text-[#626260] flex-shrink-0 mt-0.5" />
          <div>
            <p class="text-[#626260] leading-relaxed">{division.targetAudience}</p>
            <span class={`inline-block mt-3 px-3 py-1.5 rounded-lg text-xs font-medium ${tokens.badge}`}>
              {division.documentType === "IS"
                ? "Norma Internacional — sus requisitos son obligatorios para la conformidad"
                : "Informe Técnico — guía informativa y de referencia"}
            </span>
          </div>
        </div>
      </section>

      <!-- 03 Temas Clave -->
      <section class="bg-white border border-[#d3cec6] rounded-xl p-6">
        <div class="flex items-center gap-3 mb-4">
          <span class={`text-xs font-medium px-2.5 py-1 rounded-lg ${tokens.badge}`}>{nextSection()}</span>
          <h2 class="text-lg font-semibold text-[#111111]">Temas Clave</h2>
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          {division.keyTopics.map((topic) => (
            <div class="flex items-start gap-3">
              <span class={`mt-0.5 w-5 h-5 rounded-full flex-shrink-0 flex items-center justify-center text-white text-xs font-bold ${tokens.bg}`}>
                <Icon name="lucide:check" class="w-3 h-3" />
              </span>
              <span class="text-sm text-[#626260]">{topic}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- 04 Roles (solo si tiene perfil) -->
      {profile && (
        <section>
          <div class="flex items-center gap-3 mb-4">
            <span class={`text-xs font-medium px-2.5 py-1 rounded-lg ${tokens.badge}`}>{nextSection()}</span>
            <h2 class="text-lg font-semibold text-[#111111]">Roles del Perfil</h2>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {profile.roles.map((role) => <RoleCard role={role} tokens={tokens} />)}
          </div>
        </section>
      )}

      <!-- 05 Procesos (solo si tiene perfil) -->
      {profile && (
        <section>
          <div class="flex items-center gap-3 mb-4">
            <span class={`text-xs font-medium px-2.5 py-1 rounded-lg ${tokens.badge}`}>{nextSection()}</span>
            <h2 class="text-lg font-semibold text-[#111111]">Procesos del Perfil</h2>
          </div>
          <div class="space-y-4">
            {profile.processes.map((process) => (
              <ProcessSection process={process} color={profile.color} client:visible />
            ))}
          </div>
        </section>
      )}

      <!-- 06 Paquetes de despliegue (solo si tiene perfil) -->
      {profile && (
        <section class="bg-white border border-[#d3cec6] rounded-xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class={`text-xs font-medium px-2.5 py-1 rounded-lg ${tokens.badge}`}>{nextSection()}</span>
            <h2 class="text-lg font-semibold text-[#111111]">Paquetes de Despliegue</h2>
          </div>
          <p class="text-sm text-[#626260] mb-4">
            Guías detalladas que apoyan la implementación del perfil en la organización.
          </p>
          <div class="flex flex-wrap gap-2">
            {profile.deploymentPackages.map((pkg) => (
              <span class={`px-3 py-1.5 rounded-lg text-sm font-medium border ${tokens.badge} border-[#d3cec6]`}>
                <Icon name="lucide:package" class="w-4 h-4 inline-block mr-1.5" />
                {pkg}
              </span>
            ))}
          </div>
        </section>
      )}

      <!-- Navegación -->
      <div class="flex justify-between items-center pt-6 border-t border-[#ebe7e1] gap-4">
        {prev ? (
          <a href={`/perfiles/${prev.id}`} class="flex items-center gap-3 group min-w-0">
            <div class="w-10 h-10 rounded-xl bg-[#ebe7e1] group-hover:bg-[#d3cec6] flex items-center justify-center transition-colors flex-shrink-0">
              <Icon name="lucide:arrow-left" class="w-5 h-5 text-[#626260]" />
            </div>
            <div class="min-w-0">
              <p class="text-sm text-[#7b7b78]">Anterior</p>
              <p class="text-sm font-medium text-[#111111] group-hover:text-[#626260] transition-colors truncate">
                Parte {prev.partNumber} — {prev.name}
              </p>
            </div>
          </a>
        ) : <div />}

        {next ? (
          <a href={`/perfiles/${next.id}`} class="flex items-center gap-3 group text-right min-w-0">
            <div class="min-w-0">
              <p class="text-sm text-[#7b7b78]">Siguiente</p>
              <p class="text-sm font-medium text-[#111111] group-hover:text-[#626260] transition-colors truncate">
                Parte {next.partNumber} — {next.name}
              </p>
            </div>
            <div class={`w-10 h-10 rounded-xl flex items-center justify-center transition-colors flex-shrink-0 ${tokens.btn}`}>
              <Icon name="lucide:arrow-right" class="w-5 h-5 text-white" />
            </div>
          </a>
        ) : (
          <div class="flex items-center gap-3 group text-right">
            <div>
              <p class="text-sm text-[#7b7b78]">Has llegado al final</p>
              <a href="/perfiles" class="text-sm font-medium text-[#111111] hover:underline">
                Ver todos los perfiles
              </a>
            </div>
            <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center">
              <Icon name="lucide:check" class="w-5 h-5 text-green-600" />
            </div>
          </div>
        )}
      </div>

    </div>
  </main>
</Layout>
