---
import Layout from "../../layouts/Layout.astro";
import RoleCard from "../../components/profile/RoleCard.astro";
import ProfileNav from "../../components/profile/ProfileNav.astro";
import ProcessSection from "../../components/process/ProcessSection";
import { getProfile, getAdjacentProfiles, getProfileIds } from "@/lib/profiles";
import { getColorTokens } from "@/constants/profile-colors";

export function getStaticPaths() {
  return getProfileIds().map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const profile = getProfile(id!);
if (!profile) return Astro.redirect("/404");

const tokens = getColorTokens(profile.color);
const { prev, next } = getAdjacentProfiles(id!);
---

<Layout title={`${profile.name} — ISO 29110`}>
  <main class="min-h-screen bg-gray-50">
    <!-- Hero header -->
    <div class={`bg-gradient-to-br ${profile.gradient} text-white`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="flex items-center gap-2 text-sm text-white/70 mb-6">
          <a href="/" class="hover:text-white transition-colors">Inicio</a>
          <span>/</span>
          <a href="/perfiles" class="hover:text-white transition-colors">Perfiles</a>
          <span>/</span>
          <span class="text-white font-medium">{profile.name}</span>
        </div>
        <div class="flex items-start gap-5">
          <div
            class="w-16 h-16 bg-white/20 rounded-2xl flex items-center justify-center text-3xl shadow-lg flex-shrink-0"
          >
            {profile.icon}
          </div>
          <div>
            <div class="flex items-center gap-3 mb-2">
              <span class="bg-white/20 text-white text-xs font-bold px-3 py-1 rounded-full">
                Nivel {profile.level}
              </span>
              <span class="bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full">
                {profile.processes.length} proceso{profile.processes.length > 1 ? "s" : ""}
              </span>
            </div>
            <h1 class="text-3xl sm:text-4xl font-extrabold">{profile.name}</h1>
            <p class="text-white/80 mt-1 text-sm">{profile.targetAudience}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-10">
      <!-- Description + characteristics -->
      <div class="grid md:grid-cols-3 gap-6">
        <div class="md:col-span-2 bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
          <h2 class="text-lg font-bold text-gray-900 mb-3">Descripción del Perfil</h2>
          <p class="text-gray-600 leading-relaxed">{profile.description}</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
          <h2 class="text-lg font-bold text-gray-900 mb-3">Características Clave</h2>
          <ul class="space-y-2">
            {
              profile.characteristics.map((c) => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <span
                    class={`mt-0.5 w-5 h-5 rounded-full flex-shrink-0 flex items-center justify-center text-white text-xs font-bold ${tokens.bg}`}
                  >
                    ✓
                  </span>
                  {c}
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Roles -->
      <section>
        <h2 class="text-2xl font-extrabold text-gray-900 mb-4">Roles del Perfil</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {profile.roles.map((role) => <RoleCard role={role} tokens={tokens} />)}
        </div>
      </section>

      <!-- Processes (React island — interactive tabs) -->
      <section>
        <h2 class="text-2xl font-extrabold text-gray-900 mb-4">Procesos del Perfil</h2>
        <div class="space-y-6">
          {
            profile.processes.map((process) => (
              <ProcessSection process={process} color={profile.color} client:visible />
            ))
          }
        </div>
      </section>

      <!-- Deployment packages -->
      <section>
        <h2 class="text-2xl font-extrabold text-gray-900 mb-4">Paquetes de Despliegue</h2>
        <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
          <p class="text-sm text-gray-500 mb-4">
            Los paquetes de despliegue son guías detalladas que apoyan la implementación del perfil
            en la organización.
          </p>
          <div class="flex flex-wrap gap-2">
            {
              profile.deploymentPackages.map((pkg) => (
                <span
                  class={`px-3 py-1.5 rounded-lg text-sm font-medium border ${tokens.badge} ${tokens.border}`}
                >
                  📦 {pkg}
                </span>
              ))
            }
          </div>
        </div>
      </section>

      <ProfileNav prev={prev} next={next} />
    </div>
  </main>
</Layout>
