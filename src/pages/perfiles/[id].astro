---
import Layout from "../../layouts/Layout.astro";
import { getDivision, getDivisionIds, getAdjacentDivisions, getDivisions } from "@/lib/divisions";
import { getProfile } from "@/lib/profiles";
import { getColorTokens } from "@/constants/profile-colors";
import ProcessSection from "../../components/process/ProcessSection";
import RoleCard from "../../components/profile/RoleCard.astro";

export function getStaticPaths() {
  return getDivisionIds().map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const division = getDivision(id!);
if (!division) return Astro.redirect("/404");

const tokens = getColorTokens(division.color);
const { prev, next } = getAdjacentDivisions(id!);
const allDivisions = getDivisions();
const currentIndex = allDivisions.findIndex((d) => d.id === id);
const profile = division.profileId ? getProfile(division.profileId) : null;

let sectionNum = 0;
function nextSection() { sectionNum++; return String(sectionNum).padStart(2, "0"); }
---

<Layout title={`Parte ${division.partNumber} — ${division.name} — ISO/IEC 29110`}>
  <main class="min-h-screen bg-gray-50">

    <!-- Progress bar -->
    <div class="bg-white border-b border-gray-200 sticky top-16 z-40">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between gap-4">
        <div class="flex items-center gap-3 min-w-0">
          <a href="/perfiles" class="text-xs text-gray-400 hover:text-gray-700 transition-colors whitespace-nowrap">
            ← Todos los perfiles
          </a>
          <span class="text-gray-200">|</span>
          <span class="text-xs font-semibold text-gray-600 truncate">{division.name}</span>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
          <span class="text-xs text-gray-400">{currentIndex + 1} / {allDivisions.length}</span>
          <div class="w-28 h-1.5 bg-gray-100 rounded-full overflow-hidden">
            <div
              class={`h-full rounded-full ${tokens.bg}`}
              style={`width: ${((currentIndex + 1) / allDivisions.length) * 100}%`}
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Hero -->
    <div class={`bg-gradient-to-br ${division.gradient} text-white`}>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="flex items-start gap-5">
          <div class="w-16 h-16 bg-white/20 rounded-2xl flex items-center justify-center text-3xl shadow-lg flex-shrink-0">
            {division.icon}
          </div>
          <div>
            <div class="flex items-center gap-2 mb-2 flex-wrap">
              <span class="bg-white/20 text-white text-xs font-bold px-3 py-1 rounded-full">
                Módulo {currentIndex + 1} de {allDivisions.length}
              </span>
              <span class="bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full">
                Parte {division.partNumber}
              </span>
              <span class="bg-white/20 text-white text-xs font-semibold px-3 py-1 rounded-full">
                {division.documentType === "IS" ? "Norma Internacional" : "Informe Técnico"} · {division.year}
              </span>
            </div>
            <h1 class="text-2xl sm:text-3xl font-extrabold leading-snug">{division.name}</h1>
            <p class="text-white/70 mt-1 text-xs font-mono">
              ISO/IEC {division.documentType === "TR" ? "TR " : ""}29110-{division.partNumber}:{division.year}
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-8">

      <!-- 01 Descripción -->
      <section class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-4">
          <span class={`text-xs font-extrabold px-2.5 py-1 rounded-lg ${tokens.badge}`}>{nextSection()}</span>
          <h2 class="text-lg font-bold text-gray-900">Descripción</h2>
        </div>
        <p class="text-gray-600 leading-relaxed">{division.description}</p>
      </section>

      <!-- 02 Público Objetivo -->
      <section class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-4">
          <span class={`text-xs font-extrabold px-2.5 py-1 rounded-lg ${tokens.badge}`}>{nextSection()}</span>
          <h2 class="text-lg font-bold text-gray-900">Público Objetivo</h2>
        </div>
        <div class="flex items-start gap-3">
          <span class="text-2xl">👥</span>
          <div>
            <p class="text-gray-600 leading-relaxed">{division.targetAudience}</p>
            <span class={`inline-block mt-3 px-3 py-1.5 rounded-lg text-xs font-semibold ${tokens.badge}`}>
              {division.documentType === "IS"
                ? "Norma Internacional — sus requisitos son obligatorios para la conformidad"
                : "Informe Técnico — guía informativa y de referencia"}
            </span>
          </div>
        </div>
      </section>

      <!-- 03 Temas Clave -->
      <section class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-4">
          <span class={`text-xs font-extrabold px-2.5 py-1 rounded-lg ${tokens.badge}`}>{nextSection()}</span>
          <h2 class="text-lg font-bold text-gray-900">Temas Clave</h2>
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          {division.keyTopics.map((topic) => (
            <div class="flex items-start gap-3">
              <span class={`mt-0.5 w-5 h-5 rounded-full flex-shrink-0 flex items-center justify-center text-white text-xs font-bold ${tokens.bg}`}>
                ✓
              </span>
              <span class="text-sm text-gray-700">{topic}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- 04 Roles (solo si tiene perfil) -->
      {profile && (
        <section>
          <div class="flex items-center gap-3 mb-4">
            <span class={`text-xs font-extrabold px-2.5 py-1 rounded-lg ${tokens.badge}`}>{nextSection()}</span>
            <h2 class="text-lg font-bold text-gray-900">Roles del Perfil</h2>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            {profile.roles.map((role) => <RoleCard role={role} tokens={tokens} />)}
          </div>
        </section>
      )}

      <!-- 05 Procesos (solo si tiene perfil) -->
      {profile && (
        <section>
          <div class="flex items-center gap-3 mb-4">
            <span class={`text-xs font-extrabold px-2.5 py-1 rounded-lg ${tokens.badge}`}>{nextSection()}</span>
            <h2 class="text-lg font-bold text-gray-900">Procesos del Perfil</h2>
          </div>
          <div class="space-y-4">
            {profile.processes.map((process) => (
              <ProcessSection process={process} color={profile.color} client:visible />
            ))}
          </div>
        </section>
      )}

      <!-- 06 Paquetes de despliegue (solo si tiene perfil) -->
      {profile && (
        <section class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
          <div class="flex items-center gap-3 mb-4">
            <span class={`text-xs font-extrabold px-2.5 py-1 rounded-lg ${tokens.badge}`}>{nextSection()}</span>
            <h2 class="text-lg font-bold text-gray-900">Paquetes de Despliegue</h2>
          </div>
          <p class="text-sm text-gray-500 mb-4">
            Guías detalladas que apoyan la implementación del perfil en la organización.
          </p>
          <div class="flex flex-wrap gap-2">
            {profile.deploymentPackages.map((pkg) => (
              <span class={`px-3 py-1.5 rounded-lg text-sm font-medium border ${tokens.badge} ${tokens.border}`}>
                📦 {pkg}
              </span>
            ))}
          </div>
        </section>
      )}

      <!-- Navegación -->
      <div class="flex justify-between items-center pt-6 border-t border-gray-200 gap-4">
        {prev ? (
          <a href={`/perfiles/${prev.id}`} class="flex items-center gap-3 group min-w-0">
            <div class="w-10 h-10 rounded-xl bg-gray-100 group-hover:bg-gray-200 flex items-center justify-center transition-colors flex-shrink-0 font-bold text-gray-500">
              ←
            </div>
            <div class="min-w-0">
              <p class="text-xs text-gray-400">Anterior</p>
              <p class="text-sm font-semibold text-gray-800 group-hover:text-blue-600 transition-colors truncate">
                {prev.icon} Parte {prev.partNumber} — {prev.name}
              </p>
            </div>
          </a>
        ) : <div />}

        {next ? (
          <a href={`/perfiles/${next.id}`} class="flex items-center gap-3 group text-right min-w-0">
            <div class="min-w-0">
              <p class="text-xs text-gray-400">Siguiente</p>
              <p class="text-sm font-semibold text-gray-800 group-hover:text-blue-600 transition-colors truncate">
                {next.icon} Parte {next.partNumber} — {next.name}
              </p>
            </div>
            <div class={`w-10 h-10 rounded-xl flex items-center justify-center transition-colors flex-shrink-0 font-bold text-white ${tokens.btn}`}>
              →
            </div>
          </a>
        ) : (
          <div class="flex items-center gap-3 group text-right">
            <div>
              <p class="text-xs text-gray-400">Has llegado al final</p>
              <a href="/perfiles" class="text-sm font-semibold text-blue-600 hover:underline">
                Ver todos los perfiles
              </a>
            </div>
            <div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center text-green-600 font-bold">
              ✓
            </div>
          </div>
        )}
      </div>

    </div>
  </main>
</Layout>
