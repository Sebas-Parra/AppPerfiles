---
import Layout from "../layouts/Layout.astro";
import { getDivisions } from "@/lib/divisions";
import { getColorTokens } from "@/constants/profile-colors";

const divisions = getDivisions();
---

<Layout>
  <main class="min-h-screen bg-gray-50">

    <!-- Hero -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-blue-700 via-indigo-700 to-purple-800"></div>
      <div class="absolute inset-0 opacity-10"
        style="background-image: radial-gradient(circle at 25% 25%, white 1px, transparent 1px), radial-gradient(circle at 75% 75%, white 1px, transparent 1px); background-size: 40px 40px;"></div>
      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
        <span class="inline-block bg-white/10 border border-white/20 text-white text-xs font-semibold px-4 py-1.5 rounded-full mb-6">
          Norma Internacional ISO/IEC 29110
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight mb-4">
          Guía de Perfiles para<br />
          <span class="text-blue-200">Pequeñas Organizaciones</span>
        </h1>
        <p class="text-lg text-blue-100 max-w-xl mx-auto leading-relaxed mb-8">
          La ISO/IEC 29110 define cómo las VSEs (hasta 25 personas) pueden implementar buenas
          prácticas de ingeniería de software. Organizada en <strong class="text-white">6 perfiles</strong>, desde la visión general hasta las guías de implementación.
        </p>
        <a
          href="/perfiles"
          class="inline-block bg-white text-blue-700 font-bold px-8 py-3.5 rounded-xl hover:bg-blue-50 transition-colors shadow-lg text-base"
        >
          Explorar los 6 perfiles →
        </a>
      </div>
    </section>

    <!-- Stats -->
    <section class="bg-white border-b border-gray-200">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
          {[
            { label: "Perfiles del estándar", value: "6", icon: "📚" },
            { label: "Normas Internacionales", value: "5", icon: "📜" },
            { label: "Procesos documentados", value: "9+", icon: "⚙️" },
            { label: "Actividades cubiertas", value: "30+", icon: "📋" },
          ].map((stat) => (
            <div class="flex flex-col items-center gap-1">
              <span class="text-2xl">{stat.icon}</span>
              <span class="text-3xl font-extrabold text-gray-900">{stat.value}</span>
              <span class="text-sm text-gray-500 font-medium">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Profiles preview -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-extrabold text-gray-900 mb-2">Los 6 Perfiles</h2>
        <p class="text-gray-500 max-w-lg mx-auto text-sm">
          Recorre el estándar en orden. Cada perfil cubre una parte específica de la norma.
        </p>
      </div>

      <div class="space-y-3">
        {divisions.map((division, idx) => {
          const tokens = getColorTokens(division.color);
          return (
            <a
              href={`/perfiles/${division.id}`}
              class={`flex items-center gap-4 bg-white rounded-2xl border-2 ${tokens.border} ${tokens.borderHover} px-5 py-4 transition-all hover:shadow-md hover:-translate-y-0.5 group`}
            >
              <div class={`w-11 h-11 rounded-xl ${tokens.bg} flex items-center justify-center text-white font-extrabold text-sm flex-shrink-0`}>
                {String(idx + 1).padStart(2, "0")}
              </div>
              <span class="text-xl flex-shrink-0">{division.icon}</span>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-0.5 flex-wrap">
                  <span class={`text-xs font-bold px-2 py-0.5 rounded-full ${tokens.badge}`}>Parte {division.partNumber}</span>
                  <span class="text-xs text-gray-400">{division.documentType === "IS" ? "Norma Internacional" : "Informe Técnico"} · {division.year}</span>
                  {division.profileId && (
                    <span class="text-xs px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 font-semibold">Con procesos detallados</span>
                  )}
                </div>
                <p class="font-semibold text-gray-900 text-sm truncate">{division.name}</p>
              </div>
              <span class="text-gray-300 group-hover:text-gray-600 transition-colors font-bold flex-shrink-0">→</span>
            </a>
          );
        })}
      </div>

      <div class="text-center mt-8">
        <a
          href={`/perfiles/${divisions[0].id}`}
          class="inline-block bg-slate-800 text-white font-semibold px-7 py-3 rounded-xl hover:bg-slate-900 transition-colors"
        >
          Comenzar desde el Perfil 1 →
        </a>
      </div>
    </section>

    <!-- About -->
    <section class="bg-white border-t border-gray-200 py-14">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <span class="text-blue-600 font-semibold text-xs uppercase tracking-wide">¿Qué es?</span>
            <h2 class="text-2xl font-extrabold text-gray-900 mt-2 mb-4">ISO/IEC 29110</h2>
            <p class="text-gray-600 leading-relaxed mb-4">
              Conjunto de normas diseñadas para VSEs (Very Small Entities) — organizaciones de hasta
              25 personas que desarrollan software — que buscan adoptar buenas prácticas sin la
              complejidad de normas creadas para grandes empresas.
            </p>
            <p class="text-gray-600 leading-relaxed">
              Compatible con cualquier ciclo de vida: cascada, iterativo, incremental o ágil.
            </p>
          </div>
          <div class="grid grid-cols-2 gap-3">
            {[
              { icon: "🎯", title: "Para VSEs", desc: "Hasta 25 personas" },
              { icon: "📚", title: "6 Partes", desc: "Visión a implementación" },
              { icon: "🌐", title: "Internacional", desc: "ISO e IEC" },
              { icon: "✅", title: "Práctica", desc: "Guías de implementación" },
            ].map((item) => (
              <div class="bg-gray-50 rounded-xl border border-gray-200 p-4">
                <span class="text-2xl">{item.icon}</span>
                <p class="font-semibold text-gray-900 text-sm mt-2">{item.title}</p>
                <p class="text-xs text-gray-500 mt-0.5">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <footer class="bg-gray-900 text-gray-400 text-center py-5 text-sm">
      <p>Guía de referencia ISO/IEC 29110 — Perfiles de ciclo de vida para VSEs</p>
    </footer>
  </main>
</Layout>
