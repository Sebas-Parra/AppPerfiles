---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { getDivisions } from "@/lib/divisions";
import { getColorTokens } from "@/constants/profile-colors";

const divisions = getDivisions();
---

<Layout>
  <main>
    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center" data-motion="hero">
      <span class="inline-block text-xs font-medium text-[#626260] border border-[#d3cec6] px-4 py-1.5 rounded-full mb-6" data-motion-child>
        Norma Internacional ISO/IEC 29110
      </span>
      <h1 class="text-4xl sm:text-5xl font-semibold text-[#111111] leading-tight mb-4 tracking-tight" style="letter-spacing: -0.5px;" data-motion-child>
        Guía de Perfiles para<br />
        Pequeñas Organizaciones
      </h1>
      <p class="text-lg text-[#626260] max-w-xl mx-auto leading-relaxed mb-8" data-motion-child>
        La ISO/IEC 29110 define cómo las VSEs (hasta 25 personas) pueden implementar buenas
        prácticas de ingeniería de software. Organizada en <strong class="text-[#111111] font-medium">6 perfiles</strong>, desde la visión general hasta las guías de implementación.
      </p>
      <a
        href="/perfiles"
        class="inline-block bg-[#111111] text-white font-medium text-[15px] px-8 py-2.5 rounded-lg hover:bg-black transition-colors"
        data-motion-child
        data-hover="lift"
      >
        Explorar los 6 perfiles
      </a>
    </section>

    <!-- Stats -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-24" data-motion="reveal">
      <div class="bg-white border border-[#d3cec6] rounded-2xl p-8">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center" data-motion="stagger">
          {[
            { label: "Perfiles del estándar", value: "6", icon: "book-open" },
            { label: "Normas Internacionales", value: "5", icon: "scroll-text" },
            { label: "Procesos documentados", value: "9+", icon: "settings" },
            { label: "Actividades cubiertas", value: "30+", icon: "clipboard-list" },
          ].map((stat) => (
            <div class="flex flex-col items-center gap-2" data-motion-item>
              <Icon name={`lucide:${stat.icon}`} class="w-6 h-6 text-[#626260]" />
              <span class="text-3xl font-semibold text-[#111111] tracking-tight">{stat.value}</span>
              <span class="text-sm text-[#7b7b78]">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Profiles preview -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-24">
      <div class="text-center mb-10" data-motion="reveal">
        <h2 class="text-3xl font-semibold text-[#111111] mb-2 tracking-tight">Los 6 Perfiles</h2>
        <p class="text-[#626260] max-w-lg mx-auto text-base">
          Recorre el estándar en orden. Cada perfil cubre una parte específica de la norma.
        </p>
      </div>
      <div class="space-y-2.5" data-motion="stagger">
        {divisions.map((division, idx) => {
          const tokens = getColorTokens(division.color);
          return (
            <a
              href={`/perfiles/${division.id}`}
              class={`flex items-center gap-4 bg-white border border-[#d3cec6] hover:border-[#b0a99e] rounded-xl px-5 py-4 transition-all group`}
              data-motion-item
              data-hover="lift"
            >
              <div class={`w-10 h-10 rounded-lg ${tokens.bg} flex items-center justify-center text-white font-semibold text-sm flex-shrink-0`}>
                {String(idx + 1).padStart(2, "0")}
              </div>
              <Icon name={`lucide:${division.icon}`} class="w-5 h-5 text-[#626260] flex-shrink-0" />
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-0.5 flex-wrap">
                  <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${tokens.badge}`}>Parte {division.partNumber}</span>
                  <span class="text-xs text-[#7b7b78]">{division.documentType === "IS" ? "Norma Internacional" : "Informe Técnico"} · {division.year}</span>
                </div>
                <p class="font-medium text-[#111111] text-sm truncate">{division.name}</p>
              </div>
              <Icon name="lucide:arrow-right" class="w-5 h-5 text-[#d3cec6] group-hover:text-[#111111] transition-colors flex-shrink-0" />
            </a>
          );
        })}
      </div>
      <div class="text-center mt-8" data-motion="reveal">
        <a
          href={`/perfiles/${divisions[0].id}`}
          class="inline-block bg-[#111111] text-white font-medium text-[15px] px-7 py-2.5 rounded-lg hover:bg-black transition-colors"
          data-hover="lift"
        >
          Comenzar desde el Perfil 1
        </a>
      </div>
    </section>

    <!-- About -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mb-24" data-motion="reveal">
      <div class="grid md:grid-cols-2 gap-8 items-start">
        <div>
          <span class="text-sm font-medium text-[#626260]">¿Qué es?</span>
          <h2 class="text-2xl font-semibold text-[#111111] mt-2 mb-4 tracking-tight">ISO/IEC 29110</h2>
          <p class="text-[#626260] leading-relaxed mb-4">
            Conjunto de normas diseñadas para VSEs (Very Small Entities) — organizaciones de hasta
            25 personas que desarrollan software — que buscan adoptar buenas prácticas sin la
            complejidad de normas creadas para grandes empresas.
          </p>
          <p class="text-[#626260] leading-relaxed">
            Compatible con cualquier ciclo de vida: cascada, iterativo, incremental o ágil.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-3" data-motion="stagger">
          {[
            { icon: "target", title: "Para VSEs", desc: "Hasta 25 personas" },
            { icon: "book-open", title: "6 Partes", desc: "Visión a implementación" },
            { icon: "globe", title: "Internacional", desc: "ISO e IEC" },
            { icon: "check-circle", title: "Práctica", desc: "Guías de implementación" },
          ].map((item) => (
            <div class="bg-white border border-[#d3cec6] rounded-xl p-4" data-motion-item>
              <Icon name={`lucide:${item.icon}`} class="w-6 h-6 text-[#626260] mb-2" />
              <p class="font-medium text-[#111111] text-sm">{item.title}</p>
              <p class="text-sm text-[#7b7b78] mt-0.5">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
